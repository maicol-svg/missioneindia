---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const aggiornamenti = await getCollection('aggiornamenti');
  return aggiornamenti.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={entry.data.image}>
  <article class="bg-warm">
    <!-- Hero -->
    <header class="relative bg-slate-dark overflow-hidden">
      {entry.data.image && (
        <div class="absolute inset-0">
          <img src={entry.data.image} alt="" class="w-full h-full object-cover opacity-25" />
          <div class="absolute inset-0 bg-gradient-to-br from-[#2D1B0E]/90 via-[#3D2817]/85 to-[#2D1B0E]/90"></div>
        </div>
      )}
      <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-24 md:py-32">
        <a href="/aggiornamenti/" class="inline-flex items-center gap-2 text-white/60 hover:text-accent transition-colors text-sm mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Tutti gli aggiornamenti
        </a>
        <time class="text-accent font-medium text-sm tracking-widest uppercase mb-4 inline-block">
          {entry.data.date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        <h1 class="font-serif text-3xl md:text-5xl font-bold text-white leading-tight mb-6">
          {entry.data.title}
        </h1>
        <p class="text-lg text-white/70 leading-relaxed max-w-3xl">
          {entry.data.description}
        </p>
      </div>
    </header>

    <!-- Body -->
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-text prose-p:text-text-secondary prose-p:leading-relaxed prose-a:text-accent-dark prose-strong:text-text">
        <Content />
      </div>

      <div class="mt-16 pt-12 border-t border-divider/50 text-center">
        <p class="text-text-secondary mb-6">Vuoi sostenere progetti come questo?</p>
        <a href="/sostieni/" class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent text-[#2D1B0E] font-semibold hover:bg-accent-dark hover:text-white transition-all">
          Sostieni la missione
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
