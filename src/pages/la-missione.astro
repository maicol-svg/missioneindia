---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadMissione, loadGalleria } from '../lib/content';

const missione = await loadMissione();
const galleria = await loadGalleria();
---

<BaseLayout title="La Missione">

  <!-- HERO -->
  <section class="relative bg-slate-dark overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/uploads/bambini-orfanotrofio.jpg" alt="" class="w-full h-full object-cover opacity-25" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#2D1B0E]/95 via-[#3D2817]/90 to-[#2D1B0E]/95"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-28 md:py-36">
      <div class="max-w-3xl reveal">
        <span class="inline-block text-accent font-medium text-sm tracking-widest uppercase mb-4">{missione.localita}</span>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          La nostra missione<br/>
          <span class="italic text-accent">in India</span>
        </h1>
        <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-2xl">
          {missione.descrizione_breve}
        </p>
      </div>
    </div>
  </section>

  <!-- STORIA -->
  <section id="storia" class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="reveal mb-12">
        <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">La storia</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-text mb-6">Da un sogno a una casa</h2>
      </div>
      <div class="space-y-6 text-lg text-text-secondary leading-relaxed reveal reveal-delay-1">
        {missione.storia.map((paragrafo) => (
          <p>{paragrafo}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- AREE INTERVENTO -->
  <section id="aree-intervento" class="py-20 md:py-28 bg-cream">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <span class="text-accent-dark font-sans text-xs font-semibold tracking-[0.25em] uppercase mb-3 inline-block">Aree di intervento</span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-text">Cosa facciamo ogni giorno</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {missione.aree_intervento.map((area, i) => (
          <div class={`bg-white p-8 border-l-4 border-accent shadow-sm reveal reveal-delay-${i + 1}`}>
            <h3 class="font-serif text-2xl font-bold text-text mb-3">{area.titolo}</h3>
            <p class="text-text-secondary leading-relaxed">{area.descrizione}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OBIETTIVI -->
  <section id="obiettivi" class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <span class="text-accent-dark font-sans text-xs font-semibold tracking-[0.25em] uppercase mb-3 inline-block">Il nostro percorso</span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-text">Obiettivi della missione</h2>
        <p class="mt-4 text-text-secondary leading-relaxed max-w-2xl mx-auto">
          Ogni traguardo raggiunto è un passo verso un futuro migliore.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
        <div class="reveal">
          <h3 class="font-serif text-xl font-bold text-primary-dark mb-6 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            Obiettivi raggiunti
          </h3>
          <ul class="space-y-4">
            {missione.obiettivi_raggiunti.map((obj) => (
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="m5 12 5 5L20 7"/></svg>
                </div>
                <span class="text-text-secondary">{obj}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="reveal reveal-delay-1">
          <h3 class="font-serif text-xl font-bold text-accent-dark mb-6 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            Obiettivi da raggiungere
          </h3>
          <ul class="space-y-4">
            {missione.obiettivi_da_raggiungere.map((obj) => (
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full border-2 border-accent/40 shrink-0 mt-0.5"></div>
                <span class="text-text-secondary">{obj}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mt-12 text-center reveal">
        <a href="/sostieni/" class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-accent text-[#2D1B0E] font-semibold hover:bg-accent-dark hover:text-white transition-all">
          Sostieni un obiettivo
        </a>
      </div>
    </div>
  </section>

  <!-- GALLERIA -->
  {galleria.length > 0 && (
    <section id="galleria" class="py-20 md:py-28 bg-cream">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 reveal">
          <span class="text-accent-dark font-sans text-xs font-semibold tracking-[0.25em] uppercase mb-3 inline-block">Immagini dal campo</span>
          <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-text">Galleria</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {galleria.map((foto) => (
            <div
              class="aspect-square overflow-hidden cursor-pointer group"
              data-lightbox-group="india"
              data-lightbox-src={foto.image}
              data-lightbox-title={foto.title}
              data-lightbox-caption={foto.caption || ''}
            >
              <img src={foto.image} alt={foto.caption || foto.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 bg-slate-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">Insieme cambiamo destini</h2>
      <p class="text-lg text-white/70 mb-8 max-w-2xl mx-auto">
        Ogni bambino merita un futuro. Il tuo sostegno fa la differenza.
      </p>
      <a
        href="/sostieni/"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-accent text-[#2D1B0E] text-base font-semibold hover:bg-accent-dark hover:text-white transition-all"
      >
        Sostieni la missione
      </a>
    </div>
  </section>
</BaseLayout>
