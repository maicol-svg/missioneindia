---
import BaseLayout from '../layouts/BaseLayout.astro';
import contatti from '../data/contatti.json';
---

<BaseLayout title="Contatti">

  <!-- HERO -->
  <section class="relative bg-slate-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#2D1B0E]/95 via-[#3D2817]/90 to-[#2D1B0E]/95"></div>
    <div class="absolute top-0 right-0 w-2/3 h-2/3 opacity-20 pointer-events-none"
         style="background: radial-gradient(ellipse at 80% 20%, rgba(255,153,51,0.4) 0%, transparent 60%);"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-28 md:py-36">
      <div class="max-w-3xl reveal">
        <span class="inline-block text-accent font-medium text-sm tracking-widest uppercase mb-4">Restiamo in contatto</span>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          Contattaci
        </h1>
        <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-2xl">
          Scrivici per qualsiasi domanda sulla missione, sui modi per sostenerci o per offrirti come volontario.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTATTI + FORM -->
  <section class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Info -->
        <div class="reveal">
          <h2 class="font-serif text-3xl font-bold text-text mb-8">Scrivici</h2>

          <div class="space-y-6">
            <div class="bg-white p-6 shadow-sm">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-accent/15 flex items-center justify-center rounded-full shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div class="flex-1">
                  <p class="text-xs text-text-secondary uppercase tracking-wider mb-1">Email principale</p>
                  <a href={`mailto:${contatti.email}`} class="text-text font-medium hover:text-accent-dark transition-colors break-all">{contatti.email}</a>
                </div>
              </div>
            </div>

            {contatti.email_secondaria && (
              <div class="bg-white p-6 shadow-sm">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-accent/15 flex items-center justify-center rounded-full shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  </div>
                  <div class="flex-1">
                    <p class="text-xs text-text-secondary uppercase tracking-wider mb-1">Media e comunicazione</p>
                    <a href={`mailto:${contatti.email_secondaria}`} class="text-text font-medium hover:text-accent-dark transition-colors break-all">{contatti.email_secondaria}</a>
                  </div>
                </div>
              </div>
            )}

            <div class="bg-white p-6 shadow-sm">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-accent/15 flex items-center justify-center rounded-full shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div class="flex-1">
                  <p class="text-xs text-text-secondary uppercase tracking-wider mb-1">Sede legale</p>
                  <p class="text-text font-medium">{contatti.indirizzo_sede}<br/>{contatti.cap} {contatti.citta} ({contatti.provincia})</p>
                </div>
              </div>
            </div>

            <div class="bg-accent/10 p-6">
              <p class="text-xs text-accent-dark uppercase tracking-wider mb-3 font-semibold">Famiglia Efraim</p>
              <div class="space-y-2 text-sm">
                <a href={contatti.sito_chiesa} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-text hover:text-accent-dark transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                  Sito Chiesa Efraim
                </a>
                <a href={contatti.sito_kenya} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-text hover:text-accent-dark transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                  Sito Missione Kenya
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="bg-white p-8 md:p-10 shadow-sm border border-divider/50 reveal reveal-delay-1">
          <h2 class="font-serif text-3xl font-bold text-text mb-6">Inviaci un messaggio</h2>
          <form
            action="https://formsubmit.co/info@missionekenya.com"
            method="POST"
            class="space-y-5"
          >
            <input type="hidden" name="_subject" value="Missione India - Messaggio dal sito" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://missioneindia.com/contatti/?inviato=true" />
            <input type="hidden" name="_template" value="table" />
            <input type="text" name="_honey" style="display:none" />

            <div>
              <label for="nome" class="block text-sm font-medium text-text-secondary uppercase tracking-wider mb-1.5">Nome e Cognome</label>
              <input
                type="text"
                id="nome"
                name="Nome"
                required
                class="w-full px-4 py-3 border border-divider/50 bg-cream text-text focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
                placeholder="Il tuo nome"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-text-secondary uppercase tracking-wider mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="Email"
                required
                class="w-full px-4 py-3 border border-divider/50 bg-cream text-text focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
                placeholder="La tua email"
              />
            </div>
            <div>
              <label for="oggetto" class="block text-sm font-medium text-text-secondary uppercase tracking-wider mb-1.5">Motivo del contatto</label>
              <select
                id="oggetto"
                name="Oggetto"
                class="w-full px-4 py-3 border border-divider/50 bg-cream text-text focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
              >
                <option value="">Seleziona un motivo</option>
                <option value="Informazioni sul sostegno mensile">Informazioni sul sostegno mensile</option>
                <option value="Donazione libera">Donazione libera</option>
                <option value="5x1000">5x1000</option>
                <option value="Diventare volontario">Diventare volontario</option>
                <option value="Collaborazione / Partnership">Collaborazione / Partnership</option>
                <option value="Stampa e media">Stampa e media</option>
                <option value="Altro">Altro</option>
              </select>
            </div>
            <div>
              <label for="messaggio" class="block text-sm font-medium text-text-secondary uppercase tracking-wider mb-1.5">Messaggio</label>
              <textarea
                id="messaggio"
                name="Messaggio"
                rows="5"
                required
                class="w-full px-4 py-3 border border-divider/50 bg-cream text-text focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors resize-none"
                placeholder="Scrivi qui il tuo messaggio..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-accent text-[#2D1B0E] text-base font-semibold hover:bg-accent-dark hover:text-white transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
              Invia messaggio
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
