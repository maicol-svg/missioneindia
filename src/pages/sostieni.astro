---
import BaseLayout from '../layouts/BaseLayout.astro';
import pagamenti from '../data/pagamenti.json';
import missione from '../data/missione.json';
---

<BaseLayout title="Sostieni la Missione">

  <!-- HERO -->
  <section class="relative bg-slate-dark overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/uploads/bambini-orfanotrofio.jpg" alt="" class="w-full h-full object-cover opacity-30" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#2D1B0E]/90 via-[#3D2817]/85 to-[#2D1B0E]/90"></div>
    </div>
    <div class="absolute top-0 right-0 w-2/3 h-2/3 opacity-25 pointer-events-none"
         style="background: radial-gradient(ellipse at 80% 20%, rgba(255,153,51,0.4) 0%, transparent 60%);"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-28 md:py-36 text-center">
      <span class="inline-block text-accent font-medium text-sm tracking-widest uppercase mb-6 reveal">
        Insieme cambiamo destini
      </span>
      <h1 class="font-serif text-3xl md:text-5xl lg:text-6xl font-bold text-white leading-[1.15] max-w-5xl mx-auto mb-8 reveal reveal-delay-1">
        Insieme possiamo dare ai bambini<br/>
        qualcosa che dura per sempre:<br/>
        <span class="italic text-accent">la speranza.</span>
      </h1>
      <p class="text-lg md:text-xl text-white/80 italic font-serif max-w-2xl mx-auto reveal reveal-delay-2">
        Ogni aiuto lascia un segno. Ogni bambino ha un futuro.
      </p>
    </div>
  </section>

  <!-- I DUE TIER MENSILI -->
  <section id="tier" class="py-20 md:py-28 bg-cream">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Sostegno mensile</span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-text">Scegli come aiutare</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
        <!-- Tier Base 27€ -->
        <div class="relative bg-white border-4 border-primary p-8 md:p-10 shadow-lg reveal">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-14 h-14 rounded-full bg-primary/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-dark" aria-hidden="true"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4Z"/></svg>
            </div>
          </div>
          <div class="flex items-baseline gap-2 mb-2">
            <span class="font-serif text-6xl md:text-7xl font-bold text-primary-dark">{pagamenti.tier_base_importo}€</span>
            <span class="text-text-secondary text-lg">al mese</span>
          </div>
          <div class="inline-block bg-primary/15 text-primary-dark text-xs font-bold tracking-wider uppercase px-3 py-1.5 mb-6">
            {pagamenti.tier_base_label}
          </div>
          <p class="text-text-secondary font-medium mb-4">Aiuti a garantire:</p>
          <ul class="space-y-3 mb-8">
            {pagamenti.tier_base_include.map((item) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5" aria-hidden="true"><path d="m5 12 5 5L20 7"/></svg>
                <span class="text-text">{item}</span>
              </li>
            ))}
          </ul>
          <div class="bg-primary/5 p-4 mb-6">
            <p class="text-sm italic text-text-secondary">
              "Un piccolo gesto ogni giorno può portare speranza e dignità."
            </p>
          </div>
          <button
            type="button"
            class="w-full inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-primary text-white text-base font-semibold hover:bg-primary-dark transition-all opacity-60 cursor-not-allowed"
            disabled
            data-stripe-link=""
          >
            Sostieni con 27€/mese
            <span class="text-xs font-normal">(Disponibile a breve)</span>
          </button>
        </div>

        <!-- Tier Completo 39€ -->
        <div class="relative bg-white border-4 border-accent p-8 md:p-10 shadow-lg reveal reveal-delay-1">
          <div class="absolute -top-3 right-6 bg-accent text-[#2D1B0E] text-xs font-bold tracking-wider uppercase px-4 py-1.5">
            +12€ al mese &mdash; fai di più
          </div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-14 h-14 rounded-full bg-accent/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/><path d="M12 2C7.58 2 4 3.34 4 5s3.58 3 8 3 8-1.34 8-3-3.58-3-8-3z"/></svg>
            </div>
          </div>
          <div class="flex items-baseline gap-2 mb-2">
            <span class="font-serif text-6xl md:text-7xl font-bold text-accent-dark">{pagamenti.tier_completo_importo}€</span>
            <span class="text-text-secondary text-lg">al mese</span>
          </div>
          <div class="inline-block bg-accent/15 text-accent-dark text-xs font-bold tracking-wider uppercase px-3 py-1.5 mb-6">
            {pagamenti.tier_completo_label}
          </div>
          <p class="text-text-secondary font-medium mb-4">Puoi aiutare anche a garantire:</p>
          <ul class="space-y-3 mb-8">
            {pagamenti.tier_base_include.map((item) => (
              <li class="flex items-start gap-3 opacity-60">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5" aria-hidden="true"><path d="m5 12 5 5L20 7"/></svg>
                <span class="text-text text-sm">{item}</span>
              </li>
            ))}
            {pagamenti.tier_completo_aggiunge.map((item) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0 mt-0.5" aria-hidden="true"><path d="m5 12 5 5L20 7"/></svg>
                <span class="text-text font-medium">{item}</span>
              </li>
            ))}
          </ul>
          <div class="bg-accent/5 p-4 mb-6">
            <p class="text-sm italic text-text-secondary">
              "Con poco in più puoi fare molto di più. Il tuo aiuto può arrivare ancora più lontano."
            </p>
          </div>
          <button
            type="button"
            class="w-full inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-accent text-[#2D1B0E] text-base font-semibold hover:bg-accent-dark hover:text-white transition-all opacity-60 cursor-not-allowed"
            disabled
            data-stripe-link=""
          >
            Sostieni con 39€/mese
            <span class="text-xs font-normal">(Disponibile a breve)</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- DONAZIONI LIBERE -->
  <section id="libere" class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Donazioni libere</span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-text">Dona quando puoi</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Mensili -->
        <div class="bg-slate-dark text-white p-8 md:p-10 reveal">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <h3 class="font-serif text-2xl font-bold">Donazioni libere mensili</h3>
          </div>
          <p class="text-white/70 italic mb-6">Scegli tu quanto donare ogni mese.</p>
          <p class="text-white/80 leading-relaxed mb-6">
            Il tuo sostegno costante ci permette di programmare il futuro e rispondere ai bisogni più urgenti.
          </p>
          <p class="text-white/60 text-sm font-medium uppercase tracking-wide mb-3">Il tuo aiuto sostiene:</p>
          <div class="flex flex-wrap gap-2 mb-8">
            {pagamenti.libera_mensile_sostiene.map((item) => (
              <span class="inline-block px-3 py-1.5 bg-white/10 text-white text-sm">{item}</span>
            ))}
          </div>
          <button
            type="button"
            class="w-full inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-accent text-[#2D1B0E] text-base font-semibold hover:bg-accent-dark hover:text-white transition-all opacity-60 cursor-not-allowed"
            disabled
            data-stripe-link=""
          >
            Imposta donazione mensile
            <span class="text-xs font-normal">(Disponibile a breve)</span>
          </button>
        </div>

        <!-- Occasionali -->
        <div class="bg-cream border-4 border-accent p-8 md:p-10 reveal reveal-delay-1">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            </div>
            <h3 class="font-serif text-2xl font-bold text-text">Donazioni libere occasionali</h3>
          </div>
          <p class="text-text-secondary italic mb-6">Dona quando puoi.</p>
          <p class="text-text leading-relaxed mb-6">
            Anche una donazione singola può fare la differenza e portare aiuto dove c'è più bisogno.
          </p>
          <p class="text-text-secondary text-sm font-medium uppercase tracking-wide mb-3">Le offerte occasionali sostengono:</p>
          <div class="flex flex-wrap gap-2 mb-8">
            {pagamenti.libera_occasionale_sostiene.map((item) => (
              <span class="inline-block px-3 py-1.5 bg-accent/15 text-accent-dark text-sm font-medium">{item}</span>
            ))}
          </div>
          <button
            type="button"
            class="w-full inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-accent text-[#2D1B0E] text-base font-semibold hover:bg-accent-dark hover:text-white transition-all opacity-60 cursor-not-allowed"
            disabled
            data-stripe-link=""
          >
            Fai una donazione
            <span class="text-xs font-normal">(Disponibile a breve)</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- BONIFICO + PAYPAL -->
  <section id="altri-metodi" class="py-20 md:py-28 bg-cream">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Altri metodi</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-text">Bonifico o PayPal</h2>
        <p class="mt-4 text-text-secondary leading-relaxed max-w-2xl mx-auto">
          Puoi sostenerci anche con bonifico bancario o tramite PayPal.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- IBAN -->
        <div class="bg-white p-8 shadow-sm reveal">
          <h3 class="font-serif text-xl font-bold text-text mb-4 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            Bonifico bancario
          </h3>
          <div class="space-y-3 text-sm">
            <div>
              <p class="text-text-secondary uppercase text-xs tracking-wider mb-1">IBAN</p>
              <p class="font-mono text-base text-text-secondary tracking-wider break-all">{pagamenti.iban}</p>
            </div>
            <div>
              <p class="text-text-secondary uppercase text-xs tracking-wider mb-1">Intestato a</p>
              <p class="text-text font-medium">{pagamenti.intestatario}</p>
            </div>
            <div>
              <p class="text-text-secondary uppercase text-xs tracking-wider mb-1">Banca</p>
              <p class="text-text font-medium">{pagamenti.banca}</p>
            </div>
            <div class="mt-4 p-3 bg-accent/10">
              <p class="text-xs text-text"><strong>Causale:</strong> {pagamenti.causale_suggerita}</p>
            </div>
          </div>
        </div>

        <!-- PayPal -->
        <div class="bg-white p-8 shadow-sm reveal reveal-delay-1">
          <h3 class="font-serif text-xl font-bold text-text mb-4 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M7 11l1-9h6.5c2.5 0 4.5 1.5 4 4.5-.5 3-3 4.5-5.5 4.5H10l-1 6H5l2-6z"/></svg>
            PayPal
          </h3>
          <p class="text-text-secondary mb-6 leading-relaxed">
            Dona in modo sicuro tramite PayPal usando il nostro indirizzo o il link diretto.
          </p>
          <div class="space-y-3 mb-6 text-sm">
            <div>
              <p class="text-text-secondary uppercase text-xs tracking-wider mb-1">Email PayPal</p>
              <p class="font-mono text-text">{pagamenti.paypal_email}</p>
            </div>
          </div>
          <a
            href={pagamenti.paypal_link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-[#0070ba] text-white font-semibold hover:bg-[#005ea6] transition-all"
          >
            Dona con PayPal
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- VALORI -->
  <section id="valori" class="py-20 md:py-28 bg-slate-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <span class="text-accent font-sans text-xs font-semibold tracking-[0.25em] uppercase mb-3 inline-block">I nostri valori</span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white">Trasparenza e fiducia</h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="text-center p-6 bg-white/[0.04] border border-white/10 reveal">
          <div class="w-14 h-14 rounded-full bg-accent/15 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="font-serif text-lg font-bold text-white mb-2">Sicurezza</h3>
          <p class="text-white/60 text-sm">Donazioni sicure e trasparenti.</p>
        </div>
        <div class="text-center p-6 bg-white/[0.04] border border-white/10 reveal reveal-delay-1">
          <div class="w-14 h-14 rounded-full bg-accent/15 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="font-serif text-lg font-bold text-white mb-2">Impegno</h3>
          <p class="text-white/60 text-sm">Siamo presenti ogni giorno nei nostri progetti.</p>
        </div>
        <div class="text-center p-6 bg-white/[0.04] border border-white/10 reveal reveal-delay-2">
          <div class="w-14 h-14 rounded-full bg-accent/15 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
          </div>
          <h3 class="font-serif text-lg font-bold text-white mb-2">Trasparenza</h3>
          <p class="text-white/60 text-sm">Aggiornamenti reali e foto direttamente dal campo.</p>
        </div>
        <div class="text-center p-6 bg-white/[0.04] border border-white/10 reveal reveal-delay-3">
          <div class="w-14 h-14 rounded-full bg-accent/15 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
          <h3 class="font-serif text-lg font-bold text-white mb-2">Fiducia</h3>
          <p class="text-white/60 text-sm">Ogni donazione arriva dove serve davvero.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORM -->
  <section id="contatto" class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Hai domande?</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-text">Contattaci</h2>
        <p class="mt-4 text-text-secondary leading-relaxed">
          Scrivici per saperne di più sulla missione o per ricevere informazioni dettagliate sui modi per sostenerci.
        </p>
      </div>

      <div class="bg-white p-8 md:p-10 shadow-sm border border-divider/50 reveal reveal-delay-1">
        <form
          action="https://formsubmit.co/info@missionekenya.com"
          method="POST"
          class="space-y-5"
        >
          <input type="hidden" name="_subject" value="Missione India - Richiesta informazioni sostegno" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://missioneindia.com/sostieni/?inviato=true" />
          <input type="hidden" name="_template" value="table" />
          <input type="text" name="_honey" style="display:none" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="nome" class="block text-sm font-medium text-text-secondary uppercase tracking-wider mb-1.5">Nome e Cognome</label>
              <input
                type="text"
                id="nome"
                name="Nome"
                required
                class="w-full px-4 py-3 border border-divider/50 bg-cream text-text focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
                placeholder="Il tuo nome"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-text-secondary uppercase tracking-wider mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="Email"
                required
                class="w-full px-4 py-3 border border-divider/50 bg-cream text-text focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
                placeholder="La tua email"
              />
            </div>
          </div>

          <div>
            <label for="telefono" class="block text-sm font-medium text-text-secondary uppercase tracking-wider mb-1.5">Telefono <span class="normal-case tracking-normal font-normal">(facoltativo)</span></label>
            <input
              type="tel"
              id="telefono"
              name="Telefono"
              class="w-full px-4 py-3 border border-divider/50 bg-cream text-text focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
              placeholder="Il tuo numero di telefono"
            />
          </div>

          <div>
            <label for="messaggio" class="block text-sm font-medium text-text-secondary uppercase tracking-wider mb-1.5">Messaggio</label>
            <textarea
              id="messaggio"
              name="Messaggio"
              rows="4"
              class="w-full px-4 py-3 border border-divider/50 bg-cream text-text focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors resize-none"
              placeholder="Raccontaci di te o chiedici qualsiasi cosa..."
            ></textarea>
          </div>

          <div class="text-center pt-2">
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 px-10 py-3.5 bg-accent text-[#2D1B0E] text-base font-semibold hover:bg-accent-dark hover:text-white transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
              Invia richiesta
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- TAGLINE FINALE -->
  <section class="py-16 md:py-20 bg-slate-dark text-center">
    <div class="mx-auto max-w-3xl px-4">
      <p class="font-serif text-2xl md:text-3xl text-white italic leading-relaxed">
        {missione.tagline_secondaria}.<br/>
        <span class="text-accent">{missione.tagline_hero}.</span>
      </p>
    </div>
  </section>

</BaseLayout>
